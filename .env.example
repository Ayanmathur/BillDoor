# ============================================================
# BillDoor — Environment Variables Template
# ============================================================
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini API (Phase 2 — Review Flow AI generation)
GEMINI_API_KEY=your-gemini-api-key

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# License Key Encryption (admin unmask/resend feature)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret

# WhatsApp Business Cloud API — Credential Encryption (server-side only)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_ENCRYPTION_KEY=your-32-byte-hex-secret

# Razorpay — Subscription payment links (server-side only, NEVER NEXT_PUBLIC_)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Vercel Cron Secret (payment reminder job auth)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret
